---
import ThemeToggle from "./ThemeToggle.astro";
import ClickToCall from "./ClickToCall.astro";
import config from "../site.config";

interface Props {
  navItems: { href: string; label: string }[];
}

const { navItems } = Astro.props;
const currentPath = Astro.url.pathname;
---
<header
  class="border-b sticky top-0 z-40 backdrop-blur-sm"
  style="border-color:var(--color-divider);background:color-mix(in srgb, var(--color-bg) 95%, transparent)"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo / site name -->
      <a href="/" class="no-underline group" aria-label={`${config.name} — home`}>
        <span
          class="font-bold text-xl tracking-tight transition-colors"
          style="font-family:var(--font-display);color:var(--color-fg)"
        >
          {config.name}
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Navigazione principale">
        {navItems.map(({ label, href }) => (
          <a
            href={href}
            class:list={[
              "text-sm font-medium no-underline transition-colors",
              currentPath.startsWith(href) && href !== "/"
                ? ""
                : "",
            ]}
            style={
              currentPath.startsWith(href) && href !== "/"
                ? "color:var(--color-accent)"
                : "color:var(--color-muted)"
            }
          >
            {label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-2">
        {config.phone && config.leadCapture.phone && (
          <span class="hidden md:inline-flex">
            <ClickToCall />
          </span>
        )}
        {config.whatsapp && config.leadCapture.whatsappButton && (
          <a
            href={`https://wa.me/${(config.whatsapp ?? "").replace(/\D/g, "")}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp"
            class="hidden md:inline-flex p-2 rounded transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true" style="color:#25d366">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        )}
        <ThemeToggle />
        <!-- Mobile menu toggle -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded transition-colors"
          aria-label="Apri menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden md:hidden pb-4" aria-label="Menu mobile">
      <nav class="flex flex-col gap-2" aria-label="Navigazione mobile">
        {navItems.map(({ label, href }) => (
          <a
            href={href}
            class="text-sm font-medium py-2 px-3 rounded no-underline transition-colors"
            style="color:var(--color-muted)"
          >
            {label}
          </a>
        ))}
        {config.phone && config.leadCapture.phone && (
          <div class="py-2 px-3">
            <ClickToCall />
          </div>
        )}
      </nav>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
