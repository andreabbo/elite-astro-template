---
interface Props {
  title: string;
  button: { label: string; href: string };
  subtitle?: string;
}
const { title, button, subtitle } = Astro.props;
---
<section class="py-16" style="background:var(--color-primary);color:var(--color-bg)">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2
      class="font-bold text-2xl md:text-3xl mb-4"
      style="font-family:var(--font-display)"
    >
      {title}
    </h2>
    {subtitle && (
      <p class="mb-8 max-w-xl mx-auto opacity-80">{subtitle}</p>
    )}
    <a
      href={button.href}
      class="inline-block px-8 py-3 font-semibold text-sm rounded no-underline transition-colors"
      style="background:var(--color-accent);color:#ffffff"
    >
      {button.label}
    </a>
  </div>
</section>
