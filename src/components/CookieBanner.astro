---
import config from "../site.config";
const enabled = config.gdpr.cookieBanner;
const storageKey = `${config.domain}-cookie-accepted-v1`;
---
{enabled && (
  <div
    id="cookie-banner"
    class="fixed bottom-0 left-0 right-0 z-50 px-6 py-4 flex flex-col sm:flex-row items-start sm:items-center gap-4 border-t"
    style="background:var(--color-primary);color:var(--color-bg);border-color:var(--color-divider)"
    aria-live="polite"
    role="region"
    aria-label="Informativa cookie"
  >
    <p class="text-sm flex-1 leading-snug">
      Questo sito utilizza solo cookie tecnici essenziali. Continuando a navigare accetti l'uso di questi cookie.
    </p>
    <div class="flex gap-3 shrink-0">
      <button
        id="cookie-accept"
        class="text-sm font-medium px-4 py-2 rounded transition-colors"
        style="background:var(--color-bg);color:var(--color-primary)"
      >
        Accetta
      </button>
      <a
        href="/faq#privacy"
        class="text-sm font-medium px-4 py-2 border rounded transition-colors no-underline"
        style="border-color:var(--color-muted);color:var(--color-bg)"
      >
        Maggiori info
      </a>
    </div>
  </div>
)}

{enabled && (
  <script define:vars={{ storageKey }}>
    const banner = document.getElementById('cookie-banner');
    const btn = document.getElementById('cookie-accept');

    if (localStorage.getItem(storageKey) === 'true') {
      banner?.remove();
    }

    btn?.addEventListener('click', () => {
      localStorage.setItem(storageKey, 'true');
      banner?.remove();
    });
  </script>
)}
