---
import config from "../site.config";

interface Props {
  slug: string;
  title: string;
  excerpt: string;
  date: string;
  category?: string;
  image?: { src: string; alt: string };
  featured?: boolean;
}

const {
  slug,
  title,
  excerpt,
  date,
  category,
  image,
  featured = false,
} = Astro.props;

const formatted = new Date(date).toLocaleDateString(
  `${config.language}-${config.address.country.toUpperCase()}`,
  { day: "numeric", month: "long", year: "numeric" }
);

const style = config.design.style;
---

<article
  class:list={[
    "group transition-colors",
    featured && "md:col-span-2",
    style === "bold"
      ? "overflow-hidden rounded-none"
      : style === "modern"
      ? "rounded overflow-hidden"
      : style === "elegant"
      ? "border-b py-8"
      : "border rounded-sm p-6",  /* editorial */
  ]}
  style={
    style !== "elegant" && style !== "bold"
      ? "border-color:var(--color-divider)"
      : ""
  }
>
  {image && style !== "editorial" && (
    <div class:list={["overflow-hidden", style === "bold" ? "aspect-[16/9]" : "aspect-[4/3]"]}>
      <img
        src={image.src}
        alt={image.alt}
        loading="lazy"
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
      />
    </div>
  )}

  <div class:list={[style === "bold" && "p-6", style === "modern" && "p-5"]}>
    {category && (
      <div class="flex items-center gap-3 mb-3">
        <span class="tag-chip">{category}</span>
        <time datetime={date} class="text-xs" style="color:var(--color-muted)">{formatted}</time>
      </div>
    )}
    {!category && (
      <time datetime={date} class="block text-xs mb-3" style="color:var(--color-muted)">{formatted}</time>
    )}

    <h2
      class:list={[
        "font-bold leading-snug mb-3 transition-colors",
        featured ? "text-2xl md:text-3xl" : "text-xl",
      ]}
      style="font-family:var(--font-display);color:var(--color-fg)"
    >
      <a
        href={`/blog/${slug}`}
        class="no-underline"
        style={`color:var(--color-fg)`}
      >
        {title}
      </a>
    </h2>

    <p class="text-sm leading-relaxed line-clamp-3" style="color:var(--color-muted)">
      {excerpt}
    </p>

    <a
      href={`/blog/${slug}`}
      class="inline-block mt-4 text-sm font-medium no-underline hover:underline"
      style="color:var(--color-accent)"
      aria-label={`Leggi: ${title}`}
    >
      Leggi &rarr;
    </a>
  </div>
</article>
