---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ArticleCard from "../components/ArticleCard.astro";
import LeadForm from "../components/LeadForm.astro";
import Section from "../components/Section.astro";
import { getCollection } from "astro:content";
import config from "../site.config";

const allArticoli = config.pages.blog
  ? await getCollection("articoli")
  : [];

const sorted = allArticoli.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const featured = sorted.slice(0, 3);
---
<BaseLayout description={config.description}>
  <!-- Hero -->
  <Hero
    title={config.name}
    subtitle={config.tagline}
    lead={config.description}
    ctaPrimary={config.pages.contatti ? { label: "Contattaci", href: "/contatti" } : undefined}
    ctaSecondary={config.pages.blog ? { label: "Leggi il blog", href: "/blog" } : undefined}
  />

  <!-- Featured articles -->
  {config.pages.blog && (
    <Section>
      <div class="flex items-center justify-between mb-10">
        <h2
          class="font-bold text-2xl md:text-3xl"
          style="font-family:var(--font-display);color:var(--color-fg)"
        >
          {featured.length > 0 ? "Articoli recenti" : "Blog"}
        </h2>
        <a
          href="/blog"
          class="text-sm font-medium no-underline hover:underline shrink-0"
          style="color:var(--color-accent)"
        >
          Tutti gli articoli &rarr;
        </a>
      </div>

      {featured.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {featured.map((a, i) => (
            <ArticleCard
              title={a.data.title}
              slug={a.data.slug ?? a.id.replace(/\.md$/, "")}
              date={a.data.date}
              category={a.data.category}
              excerpt={a.data.excerpt}
              image={a.data.hero}
              featured={i === 0}
            />
          ))}
        </div>
      ) : (
        <p style="color:var(--color-muted)">
          Gli articoli appariranno qui una volta pubblicati.
        </p>
      )}
    </Section>
  )}

  <!-- Divider -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="section-divider"></div>
  </div>

  <!-- Chi Siamo teaser -->
  {config.pages.chiSiamo && (
    <Section>
      <div class="max-w-2xl">
        <p
          class="text-xs font-medium uppercase tracking-widest mb-4"
          style="color:var(--color-accent)"
        >
          Chi siamo
        </p>
        <h2
          class="font-bold text-2xl md:text-3xl mb-6"
          style="font-family:var(--font-display);color:var(--color-fg)"
        >
          {config.name}
        </h2>
        <p class="leading-relaxed mb-6" style="color:var(--color-muted)">
          {config.description}
        </p>
        <a
          href="/chi-siamo"
          class="inline-block text-sm font-medium no-underline hover:underline"
          style="color:var(--color-accent)"
        >
          Scopri di più &rarr;
        </a>
      </div>
    </Section>
  )}

  <!-- Divider -->
  {config.pages.contatti && config.leadCapture.form && (
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-divider"></div>
    </div>
  )}

  <!-- Lead form CTA -->
  {config.pages.contatti && config.leadCapture.form && (
    <Section>
      <div class="max-w-xl">
        <p
          class="text-xs font-medium uppercase tracking-widest mb-4"
          style="color:var(--color-accent)"
        >
          Contattaci
        </p>
        <h2
          class="font-bold text-2xl mb-3"
          style="font-family:var(--font-display);color:var(--color-fg)"
        >
          Parliamo del tuo progetto
        </h2>
        <p class="text-sm mb-6" style="color:var(--color-muted)">
          Compila il modulo e ti risponderemo entro 24 ore.
        </p>
        <LeadForm />
      </div>
    </Section>
  )}
</BaseLayout>
