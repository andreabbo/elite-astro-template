---
import BaseLayout from "../layouts/BaseLayout.astro";
import config from "../site.config";
---
<BaseLayout title="Pagina non trovata" noindex={true}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center">
    <p
      class="font-bold text-8xl mb-8 select-none"
      style="font-family:var(--font-display);color:var(--color-divider)"
      aria-hidden="true"
    >
      404
    </p>
    <h1
      class="font-bold text-3xl mb-4"
      style="font-family:var(--font-display);color:var(--color-fg)"
    >
      Pagina non trovata
    </h1>
    <p class="mb-8 max-w-md mx-auto" style="color:var(--color-muted)">
      La pagina che stai cercando non esiste o è stata spostata.
    </p>
    <a
      href="/"
      class="inline-block px-6 py-3 font-medium text-sm rounded no-underline transition-colors"
      style="background:var(--color-primary);color:var(--color-bg)"
    >
      Torna alla home
    </a>
    {config.pages.contatti && (
      <p class="mt-6 text-sm" style="color:var(--color-muted)">
        Hai bisogno di aiuto?
        <a href="/contatti" class="hover:underline" style="color:var(--color-accent)">Contattaci</a>
      </p>
    )}
  </div>
</BaseLayout>
